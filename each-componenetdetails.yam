aiops-build/
├── aiops-agent/                    # ← Main application
│   ├── __init__.py                 # Module initialization
│   ├── app.py                      # Main FastAPI application
│   ├── detection_engine.py         # Failure detection (50+ patterns)
│   ├── remediation_system.py       # Auto-remediation logic
│   ├── metrics_collector.py        # Prometheus metrics collection
│   ├── utils.py                    # Utility functions
│   ├── requirements.txt            # Python dependencies
│   └── Dockerfile                  # Container image
│
├── deploy/                         # Kubernetes manifests
│   ├── namespace.yaml              # Create aiops namespace
│   ├── rbac.yaml                   # ServiceAccount + ClusterRoles
│   ├── configmap.yaml              # Configuration
│   ├── deployment.yaml             # AIOps Agent deployment
│   └── service-monitor.yaml        # Prometheus monitoring
│
├── ollama/                         # LLM service
│   ├── Dockerfile                  # Ollama container
│   ├── start.sh                    # Model initialization script
│   └── deployment.yaml             # Ollama deployment
│
├── k8sgpt/                           # ← NEW: K8sGPT custom build
│   ├── Dockerfile                    # Multi-stage build
│   ├── build.sh                      # Build script
│   ├── startup-script.sh             # K8sGPT init script
│   ├── Makefile                      # Build automation
│   ├── config.yaml                   # K8sGPT config
│   ├── k8sgpt_client.py             # Python client wrapper
│   ├── api-wrapper.py               # API integration
│   ├── integration.py               # AIOps integration
│   ├── deployment.yaml              # K8s deployment
│   ├── README.md                    # K8sGPT documentation
│   └── .dockerignore
│
├── scripts/                        # Automation scripts
│   ├── setup.sh                    # One-command setup
│   ├── build.sh                    # Build images
│   ├── deploy.sh                   # Deploy to K8s
│   └── teardown.sh                 # Remove deployments
│
├── tests/                          # Unit tests
│   ├── __init__.py
│   ├── test_detection.py           # Detection engine tests
│   ├── test_remediation.py         # Remediation tests
│   └── test_metrics.py             # Metrics tests
│
├── compose/                        # Docker Compose
